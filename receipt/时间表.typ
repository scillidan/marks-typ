= 时间表
// cheatsheet
#divider()
[煮]
#table(stroke: none, inset: 2pt, align: left, columns: 2,
	[5@min], [白豆腐块],
	[12@min], [土豆块],
	[20@min], [半颗土豆],
	[40@min], [整颗土豆],
)
#v(.6em)
[火锅]
#table(stroke: none, inset: 2pt, align: left, columns: 2,
	[10-20@s], [响铃卷],
	[0.5-1@min], [油豆皮],
	[0.5-1@min], [豆芽],
	[1-2@min], [金针菇],
	[3-4@min], [山药段],
	[3-5@min], [藕片],
	[3-5@min], [土豆片],
	[5-@min], [冻豆腐],
	[5-8@min], [冬瓜段],
	[8-10@min], [甜玉米段],
	[8-10@min], [甜玉米段],
	[10-15@min], [白萝卜段],
	[12-15@min], [糯玉米段]
)
#set list(marker: [\*])
- 如果土豆芽短且未变色，可带根挖出并去皮，切块并浸泡15@min，高温煮熟
- 经上述操作，如果食用后中毒，茄碱毒理会在8-12@h\发作，若过量则在10@min\内
#divider()
[烤]
#table(stroke: none, inset: 2pt, align: left, columns: 2,
	[10@min], [茄子],
	[10@min], [西红柿],
	[30@min], [土豆],
	[30@min], [红薯],
	[30@min], [胡萝卜]
)